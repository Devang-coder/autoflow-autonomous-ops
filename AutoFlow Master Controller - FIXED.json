        "respondWith": "json",
        "responseBody": "={\n  \"parameters\": {\n    \"respondWith\": \"json\",\n    \"responseBody\": \"{\\n  \\\"status\\\": \\\"ok\\\",\\n  \\\"processed\\\": true,\\n  \\\"trace_id\\\": \\\"{{ $json.body.trace_id || 'unknown' }}\\\",\\n  \\\"timestamp\\\": \\\"{{ $now.toISO() }}\\\"\\n}\",\n    \"options\": {}\n  },\n  \"id\": \"i9j0k1l2-3456-78ab-cdef-90abcdef0123\",\n  \"name\": \"Webhook Response\",\n  \"type\": \"n8n-nodes-base.respondToWebhook\",\n  \"typeVersion\": 1,\n  \"position\": [400, 500]\n}",
