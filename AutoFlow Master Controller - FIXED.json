              "value": "={{ $json.body.metric_value }}",
              "type": "string"
            },
            {
              "id": "assign4",
              "name": "timestamp",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "0a3fb515-b7c9-4e41-a0e1-78ccaaeb26d0",
      "name": "Normalize Telemetry",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -144,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "// Simple anomaly detection\nconst items = $input.all();\nreturn items.map(item => {\n  const val = parseFloat(item.json.metric_value || 0);\n  const isAnomaly = val > 80;\n  return {\n    json: {\n      ...item.json,\n      is_anomaly: isAnomaly,\n      anomaly_score: val / 100,\n      detection_time: new Date().toISOString()\n    }\n  };\n});"
      },
      "id": "f01c5096-4e68-4601-bb11-2f4d02f7623b",
      "name": "Anomaly Detection",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        96
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond1",
              "leftValue": "={{ $json.is_anomaly }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "4c1f565b-e361-4d8c-9f02-ddd66bb34192",
      "name": "Is Anomaly?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        272,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "// Swarm scoring - decision engine\nconst item = $input.first().json;\nconst score = (item.anomaly_score || 0) * 0.7;\nconst severity = score > 0.7 ? 'CRITICAL' : score > 0.5 ? 'HIGH' : 'MEDIUM';\n\nreturn [{ \n  json: { \n    ...item, \n    final_score: score,\n    severity: severity,\n    decision_timestamp: new Date().toISOString()\n  } \n}];"
      },
      "id": "8c4e3a34-06a3-459f-8076-cab9d5eab7ed",
      "name": "Decision Engine",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        192
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "route1",
              "leftValue": "={{ $json.final_score }}",
              "rightValue": 0.5,
              "operator": {
                "type": "number",
                "operation": "lt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "829732f2-0f0c-48b6-8171-8a9878005ebc",
      "name": "Route Decision",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        672,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log ignored event\nconst item = $input.first().json;\nreturn [{\n  json: {\n    ...item,\n    action: 'IGNORED',\n    reason: 'Score below threshold',\n    logged_at: new Date().toISOString()\n  }\n}];"
      },
      "id": "6dd7e046-2ae6-49aa-9c45-50ed0655d651",
      "name": "Log Ignored",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        864,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "// Prepare alert payload\nconst item = $input.first().json;\nreturn [{\n  json: {\n    alert_type: 'ANOMALY_DETECTED',\n    trace_id: item.trace_id,\n    metric_name: item.metric_name,\n    metric_value: item.metric_value,\n    anomaly_score: item.anomaly_score,\n    final_score: item.final_score,\n    severity: item.severity,\n    message: `⚠️ ALERT: ${item.metric_name} = ${item.metric_value} (Score: ${item.final_score.toFixed(2)})`,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "ad48d8ca-f7a1-4caa-9dc9-06da2c63422a",
      "name": "Prepare Alert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        864,
        288
      ]
    },
    {
      "parameters": {
        "jsCode": "// Mock alert sender (replace with real Slack/Email node)\nconst item = $input.first().json;\nconsole.log('ALERT SENT:', item.message);\nreturn [{\n  json: {\n    ...item,\n    alert_sent: true,\n    sent_at: new Date().toISOString(),\n    status: 'SUCCESS'\n  }\n}];"
      },
      "id": "6eb3e546-a6f1-4819-a1ef-cedcc0b788a5",
      "name": "Send Alert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
